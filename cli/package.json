{
  "name": "@hiver.sh/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "hiver": "./packages/commands/bin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "packages/commands/bin.js",
    "packages/commands/dist",
    "packages/devtools-server/dist",
    "packages/devtools-client/dist"
  ],
  "scripts": {
    "build": "npm run build:client && npm run build:server && npm run build:commands",
    "build:inspector-client": "cd packages/devtools-client && vite build --config vite.lib.config.ts",
    "build:client": "cd packages/devtools-client && vite build",
    "build:server": "tsc -p packages/devtools-server/tsconfig.build.json",
    "build:commands": "tsc -p packages/commands/tsconfig.build.json && cp packages/commands/src/compose/compose.yaml packages/commands/dist/compose/compose.yaml",
    "cli": "DEV=1 ./packages/commands/bin.js",
    "dev": "tsx watch packages/devtools-server/src/index.ts & (cd packages/devtools-client && vite) & wait",
    "start": "PORT=5173 node packages/devtools-server/dist/index.js",
    "prepack": "npm run build && tsx scripts/client-dep.ts ^0.1.0",
    "postpack": "tsx scripts/client-dep.ts file:../client/typescript",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@hiver.sh/client": "file:../client/typescript",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-primitive": "^2.1.3",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@storybook/react-vite": "^10.4.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "lucide-react": "^0.469.0",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^7.0.0",
    "storybook": "^10.4.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.0.5",
    "zod": "^4.0.0"
  }
}
