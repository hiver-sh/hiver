{
  "agent-base": {
    "image": "hiversh/agent-base:latest",
    "microvm": "hiversh/agent-base:latest-microvm",
    "config": { "tty": true, "cwd": "/workspace" }
  },
  "claude": {
    "image": "hiversh/claude:latest",
    "microvm": "hiversh/claude:latest-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "claude" }
  },
  "codex": {
    "image": "hiversh/codex:latest",
    "microvm": "hiversh/codex:latest-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "codex" }
  },
  "copilot": {
    "image": "hiversh/copilot:latest",
    "microvm": "hiversh/copilot:latest-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "copilot" }
  },
  "opencode": {
    "image": "hiversh/opencode:latest",
    "microvm": "hiversh/opencode:latest-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "opencode" }
  },
  "antigravity": {
    "image": "hiversh/antigravity:latest",
    "microvm": "hiversh/antigravity:latest-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "agy" }
  },
  "browser": {
    "image": "hiversh/browser:latest",
    "microvm": "hiversh/browser:latest-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "/bin/sh" }
  },
  "python": {
    "image": "hiversh/python:3.13-alpine",
    "microvm": "hiversh/python:3.13-alpine-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "python" }
  },
  "node": {
    "image": "hiversh/node:alpine",
    "microvm": "hiversh/node:alpine-microvm",
    "config": { "tty": true, "cwd": "/workspace", "entrypoint": "node" }
  }
}
