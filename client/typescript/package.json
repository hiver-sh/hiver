{
  "name": "hive",
  "version": "0.0.1",
  "description": "TypeScript client for the Hive sandbox control plane.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.143",
    "@types/node": "^20.19.41",
    "googleapis": "^144.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  }
}
