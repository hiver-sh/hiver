{
  "image": ".",
  "fs": [
    {
      "backend": "local",
      "mount": "/workspace",
      "acls": [
        {
          "path": "/workspace",
          "access": "rw"
        },
        {
          "path": "/workspace/**",
          "access": "rw"
        },
        {
          "path": "/workspace/inputs/**",
          "access": "ro"
        },
        {
          "path": "/workspace/secret/**",
          "access": "deny"
        }
      ]
    }
  ],
  "egress": [
    {
      "access": "allow",
      "host": "upstream-allowed",
      "methods": [
        "GET"
      ],
      "paths": [
        "/"
      ],
      "override": {
        "headers": {
          "X-Sandbox-Agent": "agent-python"
        }
      }
    },
    {
      "access": "allow",
      "host": "go.dev",
      "methods": [
        "GET"
      ],
      "paths": [
        "/solutions/case-studies/*"
      ]
    }
  ]
}
