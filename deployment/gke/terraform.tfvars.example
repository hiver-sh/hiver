# Copy to terraform.tfvars and adjust as needed.
project_id   = "agentic-468204"
region       = "us-central1"
zone         = "us-central1-a"
cluster_name = "sandbox"

# Node spec (defaults mirror vm-config.json)
machine_type                 = "n1-standard-4"
min_cpu_platform             = "Intel Haswell"
disk_size_gb                 = 50
enable_nested_virtualization = true

# Autoscaling bounds (per zone)
min_node_count = 1
max_node_count = 3

hugepages_2m_count = 2048
